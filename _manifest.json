{
  "manifest_version": 2,
  "version": "1.0.0",
  "name": "群管理助手",
  "description": "LLM自主群管理插件 — 18个管理工具+15条快捷命令，支持禁言/踢人/设精华/公告/审批入群等，含8步安全校验护栏，按群独立配置",
  "author": {
    "name": "MaiBot Community",
    "url": "https://github.com/MaiM-with-u"
  },
  "license": "GPL-v3.0-or-later",
  "urls": {
    "repository": "https://github.com/MaiM-with-u/maibot",
    "homepage": "https://github.com/MaiM-with-u/maibot"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.99.99"
  },
  "sdk": {
    "min_version": "2.0.0",
    "max_version": "2.99.99"
  },
  "dependencies": [],
  "capabilities": [
    "api.call",
    "send.text",
    "send.hybrid",
    "config.get",
    "maisaka.context.append"
  ],
  "i18n": {
    "default_locale": "zh-CN",
    "supported_locales": ["zh-CN"]
  },
  "id": "maimai.group-admin"
}
